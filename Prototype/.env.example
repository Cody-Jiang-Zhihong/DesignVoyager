# Copy this file to .env and fill in your key.
# Your .env file is in .gitignore so it will never be committed to GitHub.

# OpenAI key (from platform.openai.com, or Portkey when GPT-4 is enabled)
OPENAI_API_KEY=paste_your_key_here

# Only needed if you are using Portkey instead of OpenAI directly.
# Leave this line commented out if you are using a normal OpenAI key.
# OPENAI_BASE_URL=https://api.portkey.ai/v1
